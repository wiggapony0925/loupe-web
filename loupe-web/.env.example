# Base URL of the loupe-backend BFF.
# Leave BLANK to use a same-origin /v1 path:
#   - dev: Vite proxies /v1 to the Cloud Run backend (see vite.config.ts)
#   - prod: nginx reverse-proxies /v1 to the backend (see nginx.conf)
# Only set this to an absolute URL if you intentionally want cross-origin calls
# (the backend must then allow this origin via CORS).
VITE_API_URL=

# ── Social sign-in (optional) ────────────────────────────────────────────────
# Set these to enable the Google / Apple buttons on Login + Signup. When blank,
# the buttons don't render and email/password still works. The IDs must match
# what the backend verifies the provider token's audience against.
#   Google: an OAuth 2.0 Web client id from console.cloud.google.com
VITE_GOOGLE_CLIENT_ID=
#   Apple: a "Services ID" from developer.apple.com (e.g. com.loupe.web)
VITE_APPLE_CLIENT_ID=

