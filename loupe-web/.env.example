# Base URL of the loupe-backend BFF.
# Leave BLANK to use a same-origin /v1 path:
#   - dev: Vite proxies /v1 to the Cloud Run backend (see vite.config.ts)
#   - prod: nginx reverse-proxies /v1 to the backend (see nginx.conf)
# Only set this to an absolute URL if you intentionally want cross-origin calls
# (the backend must then allow this origin via CORS).
VITE_API_URL=
