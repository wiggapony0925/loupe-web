{
  "name": "loupe-web",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "description": "Loupe web client — scan, value, and track your trading-card collection (React + TypeScript + Radix + SCSS), powered by the loupe-backend API.",
  "author": "Loupe",
  "homepage": "https://loupe-web-714615078104.us-central1.run.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/wiggapony0925/loupe-web.git"
  },
  "bugs": {
    "url": "https://github.com/wiggapony0925/loupe-web/issues"
  },
  "keywords": [
    "trading-cards",
    "pokemon",
    "magic-the-gathering",
    "yugioh",
    "tcg",
    "collection",
    "portfolio",
    "card-grading",
    "react"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss}\"",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:stories": "vitest run --project storybook",
    "test:contract": "node scripts/contract-check.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@loupe/chart": "*",
    "@loupe/core": "*",
    "@loupe/grade": "*",
    "@loupe/theme": "*",
    "@loupe/tokens": "*",
    "@sentry/react": "^10.60.0",
    "@stripe/react-stripe-js": "^3.10.0",
    "@stripe/stripe-js": "^5.10.0",
    "@tanstack/query-sync-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "lucide-react": "^0.460.0",
    "radix-ui": "^1.1.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.80.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.1",
    "remark-gfm": "^4.0.1",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "~19.2.10",
    "@types/react-dom": "~19.2.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^26.1.0",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "sass": "^1.83.0",
    "storybook": "^10.4.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
