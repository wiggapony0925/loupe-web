    "lucide-react": "^0.460.0",
    "radix-ui": "^1.1.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "@types/react-dom": "~19.2.1",
    "@vitejs/plugin-react": "^4.3.4",
